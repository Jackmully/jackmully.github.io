<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Company Name</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>Your Company Name</h1>
    <nav>
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#work">Our Work</a>
        <a href="#reviews">Reviews</a>
        <a href="#contact">Contact</a>
    </nav>
</header>

<section id="home">
    <h2>Reliable Construction Services</h2>
    <p>Serving [Your Area] with quality workmanship.</p>
    <a href="#contact" class="btn">Get a Quote</a>
</section>

<section id="about">
    <h2>About Us</h2>
    <p>We are a trusted construction company with years of experience in residential and commercial projects.</p>
</section>

<section id="work">
