    <p>"Great service and high quality work!" – John</p>
</section>

<section id="contact">
    <h2>Contact Us</h2>
    <p>Phone: 123-456-789</p>
    <p>Email: info@yourcompany.com</p>
</section>

<footer>
    <p>© 2026 Your Company Name</p>
</footer>

